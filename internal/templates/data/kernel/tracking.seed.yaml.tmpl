# Tracking Seed for {{.ProjectName}}
# Generated by archseed — edit and run `archseed github sync` to push to GitHub.

milestones:
  - title: "M0 — Bootstrap"
    description: "Repository structure, CI, Docker, documentation and local environment"
  - title: "M1 — Core Architecture"
    description: "Backend skeleton, frontend skeleton, database schema, auth flow"
  - title: "M2 — First Usable Version"
    description: "Core user flows, deployment pipeline, user acceptance"

labels:
  - name: "type:feature"
    color: "0e8a16"
    description: "New feature"
  - name: "type:bug"
    color: "d73a4a"
    description: "Bug report"
  - name: "type:task"
    color: "0075ca"
    description: "General task"
  - name: "type:chore"
    color: "bfd4f2"
    description: "Maintenance task"
  - name: "area:backend"
    color: "5319e7"
    description: "Backend changes"
  - name: "area:frontend"
    color: "fbca04"
    description: "Frontend changes"
  - name: "area:infra"
    color: "d4c5f9"
    description: "Infrastructure changes"
  - name: "area:docs"
    color: "c5def5"
    description: "Documentation changes"
  - name: "area:agents"
    color: "bfdadc"
    description: "Agent configuration"
  - name: "priority:p0"
    color: "b60205"
    description: "Critical priority"
  - name: "priority:p1"
    color: "d93f0b"
    description: "High priority"
  - name: "priority:p2"
    color: "e99695"
    description: "Medium priority"
  - name: "status:blocked"
    color: "000000"
    description: "Blocked by dependency"

issues:
  - title: "Create initial repository structure"
    milestone: "M0 — Bootstrap"
    labels:
      - "type:task"
      - "area:repo"
    body_template: "agent-task"
    acceptance:
      - "Directory structure created"
      - "README.md created"
      - "AGENTS.md created"
      - "project.kernel.yaml created"
      - "Documentation files created"

  - title: "Review initial architecture"
    milestone: "M0 — Bootstrap"
    labels:
      - "type:task"
      - "area:docs"
    body_template: "agent-task"
    acceptance:
      - "ADR created"
      - "Architecture documented"
      - "Decisions justified"

  - title: "Set up CI workflow"
    milestone: "M0 — Bootstrap"
    labels:
      - "type:task"
      - "area:infra"
    acceptance:
      - "CI workflow configured"
      - "Lint step runs"
      - "Test step runs"
      - "Build step runs"

  - title: "Set up Docker Compose environment"
    milestone: "M0 — Bootstrap"
    labels:
      - "type:task"
      - "area:infra"
    acceptance:
      - "docker compose up succeeds"
      - "All services start without errors"

  - title: "Create backend skeleton"
    milestone: "M1 — Core Architecture"
    labels:
      - "type:feature"
      - "area:backend"
    acceptance:
      - "Backend directory structure created"
      - "Router configured"
      - "Health check endpoint working"

  - title: "Create frontend skeleton"
    milestone: "M1 — Core Architecture"
    labels:
      - "type:feature"
      - "area:frontend"
    acceptance:
      - "Frontend directory structure created"
      - "Dev server starts"
      - "Basic routing configured"

  - title: "Run archseed doctor and fix issues"
    milestone: "M0 — Bootstrap"
    labels:
      - "type:chore"
      - "area:repo"
    acceptance:
      - "archseed doctor returns exit code 0"
      - "All required files present"
