# Environment variables for local development
# Copy to .env and fill in values

{{if eq .Stack.Database.Primary "postgres"}}DATABASE_URL=postgres://{{.ProjectName}}:{{.ProjectName}}@localhost:5432/{{.ProjectName}}?sslmode=disable
{{else if eq .Stack.Database.Primary "mysql"}}DATABASE_URL=mysql://{{.ProjectName}}:{{.ProjectName}}@localhost:3306/{{.ProjectName}}
{{else if eq .Stack.Database.Primary "sqlite"}}DATABASE_URL=file:./data/{{.ProjectName}}.db
{{else if eq .Stack.Database.Primary "mongodb"}}DATABASE_URL=mongodb://{{.ProjectName}}:{{.ProjectName}}@localhost:27017/{{.ProjectName}}?authSource=admin
{{else if eq .Stack.Database.Primary "dynamodb"}}AWS_DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
{{end}}{{if .Features.Cache}}REDIS_URL=redis://localhost:6379
{{end}}{{if .Features.Queue}}RABBITMQ_URL=amqp://localhost:5672
{{end}}{{if .Features.Storage}}MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
{{end}}{{if eq .Stack.Auth.Provider "keycloak"}}KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM={{.ProjectName}}
{{else if eq .Stack.Auth.Provider "custom"}}JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=24h
{{end}}APP_ENV=development
APP_PORT=3000
