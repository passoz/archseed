# Environment variables for local development
# Copy to .env and fill in secure values for your environment.
#
# WARNING: The values below are LOCAL DEVELOPMENT placeholders only.
# Never use them in production or shared environments.

{{if eq .Stack.Database.Primary "postgres"}}# PostgreSQL — override via .env for your local setup
POSTGRES_USER=app
POSTGRES_PASSWORD=local-dev-password
POSTGRES_DB=app
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?sslmode=disable
{{else if eq .Stack.Database.Primary "mysql"}}# MySQL — override via .env for your local setup
MYSQL_ROOT_PASSWORD=local-dev-root-password
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=local-dev-app-password
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:3306/${MYSQL_DATABASE}
{{else if eq .Stack.Database.Primary "sqlite"}}DATABASE_URL=file:./data/{{.ProjectName}}.db
{{else if eq .Stack.Database.Primary "mongodb"}}# MongoDB — override via .env for your local setup
MONGO_USER=app
MONGO_PASSWORD=local-dev-password
MONGO_DB=app
DATABASE_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@localhost:27017/${MONGO_DB}?authSource=admin
{{else if eq .Stack.Database.Primary "dynamodb"}}AWS_DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
{{end}}{{if .Features.Cache}}REDIS_URL=redis://localhost:6379
{{end}}{{if .Features.Queue}}RABBITMQ_URL=amqp://localhost:5672
{{end}}{{if .Features.Storage}}MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=local-minio-key
MINIO_SECRET_KEY=local-minio-secret
{{end}}{{if eq .Stack.Auth.Provider "keycloak"}}KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM={{.ProjectName}}
{{else if eq .Stack.Auth.Provider "custom"}}{{if eq .Stack.Frontend.BFF "go"}}# Auth managed by Go BFF (httpOnly cookies) — never exposed to frontend JavaScript
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=24h
AUTH_COOKIE_NAME=auth-token
{{else}}JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=24h
{{end}}{{end}}APP_ENV=development
APP_PORT=3000
